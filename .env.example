# ─────────────────────────────────────────────────────────────
# PayrollPro Environment Variables
# Copy this file to .env.local for local development
# ─────────────────────────────────────────────────────────────

# Set to 'false' to disable mock data and use the real API
VITE_USE_MOCK=true

# Your real API base URL (used when VITE_USE_MOCK=false)
VITE_API_URL=https://api.yourcompany.com

# App metadata
VITE_APP_NAME=PayrollPro
VITE_APP_VERSION=1.0.0
